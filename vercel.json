{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/residential", "destination": "/niches/residential.html" },
    { "source": "/commercial", "destination": "/niches/commercial.html" },
    { "source": "/airbnb", "destination": "/niches/airbnb.html" },
    { "source": "/move-in-out", "destination": "/niches/move-in-out.html" },
    { "source": "/deep-cleaning", "destination": "/niches/deep-cleaning.html" },
    { "source": "/post-construction", "destination": "/niches/post-construction.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
